<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>CRUD Cidades</title>

    <!-- Bootstrap CSS -->
    <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            rel="stylesheet"
    >

    <style>
        body {
            background-color: #f4f6f9;
        }

        .card-form {
            border: none;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .table-container {
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .titulo {
            font-weight: bold;
            color: #0d6efd;
        }

        .subtitulo {
            color: #6c757d;
        }
    </style>
</head>

<body>

<div class="container py-5">

    <!-- Cabeçalho -->
    <div class="text-center mb-5">
        <h1 class="titulo">GERENCIAMENTO DE CIDADES</h1>
        <p class="subtitulo">
            Um CRUD para criar, alterar, excluir e listar cidades
        </p>
    </div>

    <!-- Formulário -->
    <div class="card card-form p-4 mb-5">
        <form>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label for="nome" class="form-label">
                        Cidade
                    </label>

                    <input
                            type="text"
                            class="form-control"
                            placeholder="Informe o nome da cidade"
                            id="nome"
                    >
                </div>

                <div class="col-md-6 mb-3">
                    <label for="estado" class="form-label">
                        Estado
                    </label>

                    <input
                            type="text"
                            class="form-control"
                            placeholder="Informe o estado ao qual a cidade pertence"
                            id="estado"
                    >
                </div>

            </div>

            <div class="text-end">
                <button
                        type="submit"
                        class="btn btn-primary px-4"
                >
                    CRIAR
                </button>
            </div>

        </form>
    </div>

    <!-- Tabela -->
    <div class="table-responsive table-container bg-white p-3">

        <table class="table table-hover align-middle mb-0">

            <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Estado</th>
                <th class="text-center">Ações</th>
            </tr>
            </thead>

            <tbody>
            </#list listaCidades as cidade>
            <tr>
                <td>${cidade.nome}</td>
                <td>${cidade.estado}</td>

                <td>
                    <div class="d-flex justify-content-center gap-2">
                        
                        <button class="btn btn-warning btn-sm">
                            ALTERAR
                        </button>

                        <button class="btn btn-danger btn-sm">
                            EXCLUIR
                        </button>

                    </div>
                </td>
            </tr>

            </tbody>#list>

        </table>

    </div>

</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>